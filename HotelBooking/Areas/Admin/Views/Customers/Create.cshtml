@{
    ViewBag.Title = "Thêm khách hàng mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h2 class="mb-4">Thêm khách hàng mới</h2>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Thông tin khách hàng</h5>
        </div>
        <div class="card-body">
            <form id="customerForm">
                @Html.AntiForgeryToken()

                <div id="success-message" class="alert alert-success alert-dismissible fade show" style="display:none;" role="alert">
                    <span></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <div id="error-message" class="alert alert-danger alert-dismissible fade show" style="display:none;" role="alert">
                    <span></span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="FullName" class="form-label">
                            Họ và tên <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" id="FullName" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="Phone" class="form-label">
                            Số điện thoại <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" id="Phone" placeholder="Ví dụ: 0901234567" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="Email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="Email" placeholder="example@gmail.com" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="Address" class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" id="Address" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="Notes" class="form-label">Ghi chú (nếu có)</label>
                    <textarea class="form-control" id="Notes" rows="3" placeholder="Ví dụ: Khách VIP, thích phòng view biển..."></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-save"></i> Thêm khách hàng
                    </button>
                    <a href="@Url.Action("Index", "Customers")" class="btn btn-secondary btn-lg">
                        <i class="fas fa-arrow-left"></i> Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $("#customerForm").submit(function (e) {
                e.preventDefault();
                addCustomer();
            });
        });

        function addCustomer() {
            var fullName = $("#FullName").val().trim();
            var phone = $("#Phone").val().trim();

            if (!fullName) {
                showError("Vui lòng nhập họ và tên!");
                return;
            }
            if (!phone) {
                showError("Vui lòng nhập số điện thoại!");
                return;
            }
            // Validate số điện thoại cơ bản (10 số, bắt đầu bằng 0)
            if (!/^0[3|5|7|8|9]\d{8}$/.test(phone)) {
                showError("Số điện thoại không hợp lệ! Vui lòng nhập đúng 10 số.");
                return;
            }

            var formData = {
                FullName: fullName,
                Phone: phone,
                Email: $("#Email").val().trim(),
                Address: $("#Address").val().trim(),
                Notes: $("#Notes").val().trim()
            };

            $.ajax({
                type: "POST",
                url: window.location.origin + '/Admin/Customers/CreateCustomer',  // Action sẽ tạo bên dưới
                data: JSON.stringify(formData),
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {
                    if (response.success) {
                        showSuccess(response.message || "Thêm khách hàng thành công!");
                        setTimeout(function () {
                            window.location.href = '/Admin/Customers';
                        }, 1500);
                    } else {
                        showError(response.message || "Có lỗi xảy ra!");
                    }
                },
                error: function () {
                    showError("Lỗi kết nối server. Vui lòng thử lại!");
                }
            });
        }

        function showSuccess(msg) {
            $("#success-message span").text(msg);
            $("#success-message").show();
            $("#error-message").hide();
        }

        function showError(msg) {
            $("#error-message span").text(msg);
            $("#error-message").show();
            $("#success-message").hide();
        }
    </script>
}